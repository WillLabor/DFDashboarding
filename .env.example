# ── App environment ──────────────────────────────────────────────────────────
# "development" enables local dev fallbacks (simulated auth, file-based secrets).
# "production" requires Azure Easy Auth, Key Vault, and Azure SQL.
APP_ENV=development

# ── Azure SQL Database ──────────────────────────────────────────────────────
# For local dev with SQLite, leave this as-is.
# For Azure SQL:
#   mssql+pyodbc://user:pass@server.database.windows.net/dbname?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes
AZURE_SQL_CONNECTION_STRING=sqlite:///local.db

# ── Azure Key Vault ─────────────────────────────────────────────────────────
# Required in production. In dev mode, secrets are stored in .dev_secrets.json.
# KEY_VAULT_URL=https://kv-lfmanalytics-pilot.vault.azure.net/

# ── LFM API ─────────────────────────────────────────────────────────────────
LFM_API_BASE_URL=https://data.localfoodmarketplace.com

# For running dashboard.py directly (local dev only):
# LFM_API_KEY=your-api-key-here

# ── Local dev: simulate Azure Easy Auth identity ────────────────────────────
DEV_USER_OBJECT_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=dev@example.com
DEV_USER_NAME=Dev User
